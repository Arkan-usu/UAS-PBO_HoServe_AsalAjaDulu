<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hoserve.client.controller.LoginController">
   <children>
      <VBox alignment="CENTER" fillWidth="false" spacing="25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox alignment="CENTER" prefWidth="420.0" spacing="20.0" styleClass="glass-card">
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
               <children>
                  <VBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label styleClass="title-header" text="HoServe" />
                        <Label styleClass="title-sub" text="Clinic Management System" />
                     </children>
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </VBox>
                  <VBox alignment="CENTER_LEFT" prefWidth="340.0" spacing="8.0">
                     <children>
                        <Label styleClass="label-form" text="USERNAME" />
                        <TextField fx:id="txtUsername" prefHeight="40.0" prefWidth="340.0" promptText="Masukkan username" styleClass="text-input" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER_LEFT" prefWidth="340.0" spacing="8.0">
                     <children>
                        <Label styleClass="label-form" text="PASSWORD" />
                        <PasswordField fx:id="txtPassword" prefHeight="40.0" prefWidth="340.0" promptText="Masukkan password" styleClass="text-input" />
                     </children>
                  </VBox>
                  <Label fx:id="lblError" textFill="#ff416c" wrapText="true" alignment="CENTER" textAlignment="CENTER">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Label>
                  <Button fx:id="btnLogin" mnemonicParsing="false" onAction="#handleLogin" prefHeight="45.0" prefWidth="340.0" styleClass="btn-primary" text="MASUK" />
                  <Hyperlink onAction="#handleGoToRegister" text="Belum punya akun? Registrasi Pasien baru" textFill="#00d2ff">
                     <font>
                        <Font size="12.0" />
                     </font>
                  </Hyperlink>
               </children>
            </VBox>
         </children>
      </VBox>
      <Button mnemonicParsing="false" onAction="#handleBackToHome" styleClass="sidebar-btn" text="&lt; Kembali ke Beranda" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0" />
   </children>
</AnchorPane>
