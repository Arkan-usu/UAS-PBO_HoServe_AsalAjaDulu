<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="768.0" prefWidth="1024.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hoserve.client.controller.HomeController">
   <children>
      <HBox prefHeight="100.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <!-- SIDEBAR -->
            <VBox prefWidth="240.0" spacing="10.0" styleClass="glass-card" HBox.hgrow="NEVER">
               <children>
                  <VBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label styleClass="title-header" text="HoServe">
                           <font>
                              <Font size="22.0" />
                           </font>
                        </Label>
                        <Label styleClass="title-sub" text="Portal Utama" />
                     </children>
                     <VBox.margin>
                        <Insets bottom="30.0" top="20.0" />
                     </VBox.margin>
                  </VBox>
                  <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-btn, sidebar-btn-active" text="Beranda" />
                  <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRedirectToLogin" styleClass="sidebar-btn" text="Buat Reservasi Baru" />
                  <VBox VBox.vgrow="ALWAYS" />
                  <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRedirectToLogin" styleClass="sidebar-btn" text="Login / Registrasi" textFill="#00d2ff">
                     <VBox.margin>
                        <Insets bottom="20.0" />
                     </VBox.margin>
                  </Button>
               </children>
               <padding>
                  <Insets left="10.0" right="10.0" />
               </padding>
            </VBox>
            
            <!-- MAIN CONTENT AREA -->
            <VBox prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
               <padding>
                  <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
               </padding>
               <children>
                  <!-- HEADER BAR -->
                  <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="10.0">
                     <children>
                        <VBox alignment="CENTER_LEFT">
                           <children>
                              <Label styleClass="title-header" text="Selamat Datang di HoServe" />
                              <Label styleClass="title-sub" text="Sistem Manajemen Klinik Modern" />
                           </children>
                        </VBox>
                     </children>
                     <VBox.margin>
                        <Insets bottom="20.0" />
                     </VBox.margin>
                  </HBox>
                  
                  <!-- PANELS STACK -->
                  <StackPane VBox.vgrow="ALWAYS">
                     <children>
                        
                        <!-- PANEL BOOKING (DUMMY) -->
                        <HBox spacing="25.0">
                           <children>
                              <!-- Booking Form (Left) -->
                              <VBox prefWidth="440.0" spacing="15.0" styleClass="glass-card" HBox.hgrow="NEVER">
                                 <padding>
                                    <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                                 </padding>
                                 <children>
                                    <Label styleClass="label-form" text="FORM RESERVASI ONLINE" textFill="#00d2ff">
                                       <font>
                                          <Font size="14.0" />
                                       </font>
                                       <VBox.margin>
                                          <Insets bottom="10.0" />
                                       </VBox.margin>
                                    </Label>
                                    
                                    <VBox spacing="6.0">
                                       <children>
                                          <Label styleClass="label-form" text="1. PILIH POLIKLINIK" />
                                          <ComboBox maxWidth="1.7976931348623157E308" prefHeight="40.0" promptText="Pilih Poliklinik" styleClass="combo-box" />
                                       </children>
                                    </VBox>
                                    
                                    <VBox spacing="6.0">
                                       <children>
                                          <Label styleClass="label-form" text="2. PILIH DOKTER" />
                                          <ComboBox maxWidth="1.7976931348623157E308" prefHeight="40.0" promptText="Pilih Dokter" styleClass="combo-box" />
                                       </children>
                                    </VBox>
                                    
                                    <VBox spacing="6.0">
                                       <children>
                                          <Label styleClass="label-form" text="3. TENTUKAN TANGGAL KUNJUNGAN" />
                                          <DatePicker maxWidth="1.7976931348623157E308" prefHeight="40.0" promptText="Pilih tanggal periksa" styleClass="date-picker" />
                                       </children>
                                    </VBox>
                                    
                                    <VBox spacing="6.0" VBox.vgrow="ALWAYS">
                                       <children>
                                          <Label styleClass="label-form" text="4. JELASKAN KELUHAN ANDA" />
                                          <TextArea prefHeight="100.0" promptText="Tuliskan keluhan atau gejala sakit yang dirasakan..." styleClass="text-input" wrapText="true" />
                                       </children>
                                    </VBox>
                                    
                                    <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRedirectToLogin" prefHeight="45.0" styleClass="btn-primary" text="AMBIL NOMOR ANTREAN (LOGIN)" />
                                 </children>
                              </VBox>
                              
                              <!-- Info Card (Right) -->
                              <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <!-- Informational Card -->
                                    <VBox spacing="15.0" styleClass="glass-card" VBox.vgrow="ALWAYS">
                                       <padding>
                                          <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                       </padding>
                                       <children>
                                          <Label styleClass="title-sub" text="Petunjuk Reservasi:" textFill="#00d2ff">
                                             <font>
                                                <Font name="System Bold" size="14.0" />
                                             </font>
                                          </Label>
                                          <Label text="1. Silahkan Login atau Registrasi terlebih dahulu." textFill="WHITE" />
                                          <Label text="2. Pilih Poliklinik tujuan Anda." textFill="WHITE" />
                                          <Label text="3. Pilih Dokter spesialis yang bertugas." textFill="WHITE" />
                                          <Label text="4. Tentukan tanggal periksa." textFill="WHITE" />
                                          <Label text="5. Tuliskan keluhan secara singkat dan jelas." textFill="WHITE" />
                                          <Label text="6. Klik tombol 'Ambil Nomor Antrean' untuk memproses booking." textFill="WHITE" />
                                          <VBox VBox.vgrow="ALWAYS" />
                                          <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRedirectToLogin" prefHeight="45.0" styleClass="btn-secondary" text="Masuk ke Akun Pasien / Dokter / Admin" />
                                       </children>
                                    </VBox>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </StackPane>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>
